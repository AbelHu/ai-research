# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# Never commit real secrets. These are read from the environment at runtime
# and are never written to the database, logs, or the audit trail.
# ---------------------------------------------------------------------------

# --- GitHub Models (default AI provider) -----------------------------------
# Fine-grained Personal Access Token with the `models: read` permission.
# Create one at: GitHub -> Settings -> Developer settings ->
#   Personal access tokens -> Fine-grained tokens (permission: "Models" = Read).
GITHUB_MODELS_TOKEN=

# Optional: your organization login. When set, requests use the
# org-attributed endpoint (https://models.github.ai/orgs/<org>/inference)
# so usage is tracked against your enterprise organization.
GITHUB_ORG=

# --- Bing Web Search (used by the web.search skill; optional for now) -------
BING_SEARCH_KEY=

# --- Alternative providers (only if you switch in config/models.yaml) ------
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
