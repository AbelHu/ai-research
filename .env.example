# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# Never commit real secrets. These are read from the environment at runtime
# and are never written to the database, logs, or the audit trail.
# ---------------------------------------------------------------------------

# --- GitHub Models (default AI provider) -----------------------------------
# Fine-grained Personal Access Token with the `models: read` permission.
# Create one at: GitHub -> Settings -> Developer settings ->
#   Personal access tokens -> Fine-grained tokens (permission: "Models" = Read).
GITHUB_MODELS_TOKEN=

# Optional: your organization login. When set, requests use the
# org-attributed endpoint (https://models.github.ai/orgs/<org>/inference)
# so usage is tracked against your enterprise organization.
GITHUB_ORG=

# --- Web search (optional; enables the `web.search` skill) ------------------
# Tavily managed search (free tier ~1,000 searches/month, no credit card):
# https://app.tavily.com/home  → create an API key. Leave blank to skip — the
# assistant works without it (weather and other special-data answers don't need
# search; general web search simply stays off until a key is set).
TAVILY_API_KEY=

# --- Telegram bot (channel adapter, §10) -----------------------------------
# Create a bot with @BotFather and paste its token here to run the chat bot
# (`python -m app.cli.telegram`). Only the paired owner can drive it (§10.1).
TELEGRAM_BOT_TOKEN=
# Optional: a secret token to verify inbound webhook requests (webhook mode).
TELEGRAM_WEBHOOK_SECRET=

# Optional: pin the owner's GitHub login so a chat device-flow pairing must
# approve as exactly this account (§10.1). When unset, the first host-side
# pairing establishes the owner.
OWNER_GITHUB_LOGIN=

# --- Alternative providers (only if you switch in config/models.yaml) ------
# OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY=
