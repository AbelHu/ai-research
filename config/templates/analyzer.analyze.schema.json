{
  "type": "object",
  "title": "Analysis",
  "properties": {
    "belongs": { "type": "boolean" },
    "kind": { "type": "string", "enum": ["ask", "task", "feature"] },
    "clarity": { "type": "string", "enum": ["clear", "unclear"] },
    "complexity": { "type": "string", "enum": ["simple", "complex"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rationale": { "type": "string" },
    "plan": {
      "type": ["object", "null"],
      "properties": {
        "phases": { "type": "array", "items": { "type": "string" } }
      }
    },
    "clarify": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    }
  },
  "required": ["belongs", "kind", "clarity", "complexity", "confidence", "rationale"],
  "additionalProperties": false
}
