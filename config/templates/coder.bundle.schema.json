        "additionalProperties": false
      }
    },
    "test_files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string", "pattern": "^[a-z0-9_]+\\.py$" },
          "code": { "type": "string", "minLength": 1 }
        },
        "required": ["filename", "code"],
        "additionalProperties": false
      }
    },
    "rationale": { "type": "string" }
  },
  "required": ["files"],
  "additionalProperties": false
}
